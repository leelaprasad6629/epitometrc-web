datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String        @id @default(uuid())
  name          String
  email         String        @unique
  contactNumber String?
  passwordHash  String
  role          String        @default("Student") // Student, Employee, Admin
  status        String        @default("Active")
  createdAt     DateTime      @default(now())
  enrollments   Enrollment[]
  applications  Application[]
  profile       UserProfile?
}

model UserProfile {
  id               String  @id @default(uuid())
  userId           String  @unique
  profile          Json?
  confidenceScores Json?
  updatedAt        DateTime @updatedAt
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id          String       @id @default(uuid())
  title       String
  category    String
  description String
  duration    String
  modules     Int
  image       String
  enrollments Enrollment[]
}

model Enrollment {
  id          String   @id @default(uuid())
  userId      String
  courseId    String
  progress    Int      @default(0)
  completedAt DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attendances Attendance[]
}

model Job {
  id           String        @id @default(uuid())
  title        String
  category     String
  location     String
  type         String
  description  String
  status       String        @default("Active")
  applications Application[]
}

model Application {
  id        String   @id @default(uuid())
  userId    String
  jobId     String
  status    String   @default("Reviewing") // Reviewing, Interviewing, Approved, Rejected
  appliedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Enquiry {
  id         String   @id @default(uuid())
  name       String
  email      String
  subject    String
  message    String
  status     String   @default("Pending") // Pending, In Progress, Completed
  receivedAt DateTime @default(now())
}

model Attendance {
  id           String   @id @default(uuid())
  enrollmentId String
  status       String   @default("Present") // Present, Absent
  date         String   // "YYYY-MM-DD"
  updatedAt    DateTime @updatedAt
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}

model Lead {
  id                    String   @id @default(uuid())
  name                  String
  email                 String
  requirements          String
  leadScore             Int      @default(0)
  priority              String   @default("Warm") // Hot, Warm, Cold
  industry              String?
  companySize           String?
  businessNeed          String?
  conversionProbability Int      @default(0)
  explanation           String?
  painPoints            String?  // JSON string
  opportunities         String?  // JSON string
  risks                 String?  // JSON string
  recommendedServices   String?  // JSON string
  recommendedNextAction String?
  status                String   @default("Qualified") // Qualified, Disqualified, Override
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Proposal {
  id                 String   @id @default(uuid())
  clientName         String
  requirements       String
  companyOverview    String
  projectScope       String
  services           String   // JSON string
  timeline           String   // JSON string
  deliverables       String   // JSON string
  totalPrice         String
  priceBreakdown     String   // JSON string
  termsAndConditions String
  status             String   @default("Draft") // Draft, Sent, Accepted, Rejected
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model CRMClient {
  id                 String   @id @default(uuid())
  name               String
  email              String
  company            String
  status             String   @default("Lead")
  health             String   @default("Active") // Active, Inactive
  summary            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  interactions       CRMInteraction[]
  actionItems        CRMActionItem[]
}

model CRMInteraction {
  id          String   @id @default(uuid())
  clientId    String
  date        String
  type        String   // Email, Meeting, Call, Ticket
  description String
  participant String
  createdAt   DateTime @default(now())
  client      CRMClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model CRMActionItem {
  id          String   @id @default(uuid())
  clientId    String
  description String
  priority    String   // High, Medium, Low
  status      String   @default("Pending") // Pending, Completed
  createdAt   DateTime @default(now())
  client      CRMClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model RecordVersion {
  id            String   @id @default(uuid())
  recordId      String
  recordType    String   // Proposal, Lead, CRMClient, Job, Course, Attendance
  version       String   // v1.0, v1.1, etc.
  createdAt     DateTime @default(now())
  userId        String?
  changeSummary String
  snapshot      String   // Full JSON snapshot
}
